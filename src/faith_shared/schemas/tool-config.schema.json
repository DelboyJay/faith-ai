{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FAITH Tool Config",
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "schema_version": {"type": "string"},
        "mounts": {"type": "object"}
      },
      "required": ["schema_version"]
    },
    {
      "type": "object",
      "properties": {
        "schema_version": {"type": "string"},
        "internet_access": {"type": "boolean"}
      },
      "required": ["schema_version"]
    },
    {
      "type": "object",
      "properties": {
        "schema_version": {"type": "string"},
        "connections": {"type": "object"}
      },
      "required": ["schema_version"]
    },
    {
      "type": "object",
      "properties": {
        "schema_version": {"type": "string"},
        "source_type": {"enum": ["registry"]},
        "registry_ref": {"type": "string"},
        "package_version": {"type": "string"},
        "transport": {"enum": ["stdio"]},
        "enabled": {"type": "boolean"}
      },
      "required": ["schema_version", "registry_ref", "package_version"]
    }
  ]
}
